<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Room <%= roomId %></title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      padding: 40px 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 32px;
      width: 100%;
      max-width: 500px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    h1 {
      font-size: 20px;
      color: #111;
      margin-bottom: 4px;
    }

    .room-id {
      font-family: monospace;
      font-size: 24px;
      font-weight: 700;
      color: #6c63ff;
      letter-spacing: 2px;
    }

    .copy-btn {
      background: none;
      border: 1px solid #ddd;
      border-radius: 6px;
      padding: 4px 10px;
      font-size: 12px;
      cursor: pointer;
      margin-left: 8px;
      color: #666;
    }

    .copy-btn:hover { background: #f0f0f0; }

    .status-row {
      display: flex;
      align-items: center;
      gap: 8px;
      margin: 20px 0;
      font-size: 14px;
      color: #555;
    }

    .dot {
      width: 10px;
      height: 10px;
      border-radius: 50%;
      background: #ccc;
      flex-shrink: 0;
    }

    .dot.waiting { background: #f0a500; animation: pulse 1.5s infinite; }
    .dot.connected { background: #22c55e; }
    .dot.disconnected { background: #ef4444; }

    @keyframes pulse {
      0%, 100% { opacity: 1; }
      50% { opacity: 0.4; }
    }

    .divider {
      border: none;
      border-top: 1px solid #eee;
      margin: 20px 0;
    }

    .dropzone {
      border: 2px dashed #ddd;
      border-radius: 10px;
      padding: 40px 20px;
      text-align: center;
      cursor: pointer;
      transition: all 0.2s;
      color: #999;
      font-size: 14px;
    }

    .dropzone:hover, .dropzone.dragover {
      border-color: #6c63ff;
      background: #f9f8ff;
      color: #6c63ff;
    }

    .dropzone input { display: none; }

    .file-preview {
      display: none;
      background: #f9f9f9;
      border-radius: 8px;
      padding: 12px 16px;
      margin-top: 12px;
      font-size: 13px;
      color: #444;
    }

    .file-preview span { font-weight: 600; color: #111; }

    .send-btn {
      width: 100%;
      margin-top: 12px;
      padding: 12px;
      background: #6c63ff;
      color: white;
      border: none;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      transition: background 0.2s;
    }

    .send-btn:hover { background: #574fd6; }
    .send-btn:disabled { background: #ccc; cursor: not-allowed; }

    .progress-wrap {
      margin-top: 16px;
      display: none;
    }

    .progress-label {
      font-size: 13px;
      color: #555;
      margin-bottom: 6px;
      display: flex;
      justify-content: space-between;
    }

    .progress-bar-bg {
      background: #eee;
      border-radius: 99px;
      height: 8px;
      overflow: hidden;
    }

    .progress-bar-fill {
      height: 100%;
      background: #6c63ff;
      border-radius: 99px;
      width: 0%;
      transition: width 0.2s;
    }

    .history-link {
      margin-top: 20px;
      font-size: 13px;
      color: #999;
      text-align: center;
    }

    .history-link a { color: #6c63ff; text-decoration: none; }
  </style>
</head>
<body>

  <div class="card">
    <h1>Room</h1>
    <div style="display:flex;align-items:center;margin-bottom:4px">
      <span class="room-id"><%= roomId %></span>
      <button class="copy-btn" onclick="copyLink()">Copy link</button>
    </div>
    <div style="font-size:12px;color:#aaa;margin-bottom:8px">Share this room ID with the other person</div>

    <div class="status-row">
      <div class="dot waiting" id="status-dot"></div>
      <span id="status">Waiting for peer to join...</span>
    </div>

    <hr class="divider">

    <div id="send-section" style="display:none">
      <div class="dropzone" id="dropzone" onclick="document.getElementById('file-input').click()">
        <input type="file" id="file-input" onchange="onFileSelected(this.files[0])">
        Drop a file here or click to choose
      </div>

      <div class="file-preview" id="file-preview">
        Selected: <span id="file-name"></span> — <span id="file-size"></span>
      </div>

      <button class="send-btn" id="btn-send" onclick="onSendClick()" disabled>
        Send file
      </button>

      <div class="progress-wrap" id="progress-wrap">
        <div class="progress-label">
          <span id="progress-text">Sending...</span>
          <span id="progress-percent">0%</span>
        </div>
        <div class="progress-bar-bg">
          <div class="progress-bar-fill" id="progress-bar"></div>
        </div>
      </div>
    </div>

    <div id="receive-section">
      <div class="progress-wrap" id="receive-progress-wrap">
        <div class="progress-label">
          <span id="receive-text">Receiving...</span>
          <span id="receive-percent">0%</span>
        </div>
        <div class="progress-bar-bg">
          <div class="progress-bar-fill" id="receive-bar" style="background:#22c55e"></div>
        </div>
      </div>
    </div>
  </div>

  <div class="history-link">
    <a href="/history">View transfer history</a>
  </div>

  <script src="/socket.io/socket.io.js"></script>
  <script src="/js/socket-client.js"></script>
  <script src="/js/webrtc.js"></script>
  <script>
    init('<%= roomId %>');

    let selectedFile = null;

    function onFileSelected(file) {
      if (!file) return;
      selectedFile = file;
      document.getElementById('file-preview').style.display = 'block';
      document.getElementById('file-name').textContent = file.name;
      document.getElementById('file-size').textContent = formatSize(file.size);
      document.getElementById('btn-send').disabled = false;
    }

    function onSendClick() {
      if (selectedFile) sendFile(selectedFile);
    }

    function copyLink() {
      navigator.clipboard.writeText(window.location.href);
      const btn = document.querySelector('.copy-btn');
      btn.textContent = 'Copied!';
      setTimeout(() => btn.textContent = 'Copy link', 2000);
    }

    // drag and drop
    const dropzone = document.getElementById('dropzone');
    dropzone.addEventListener('dragover', (e) => {
      e.preventDefault();
      dropzone.classList.add('dragover');
    });
    dropzone.addEventListener('dragleave', () => dropzone.classList.remove('dragover'));
    dropzone.addEventListener('drop', (e) => {
      e.preventDefault();
      dropzone.classList.remove('dragover');
      const file = e.dataTransfer.files[0];
      if (file) onFileSelected(file);
    });
  </script>

</body>
</html>