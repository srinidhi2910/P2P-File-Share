<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>P2P File Share</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: system-ui, sans-serif;
      background: #f5f5f5;
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }

    .card {
      background: white;
      border-radius: 12px;
      padding: 40px 32px;
      width: 100%;
      max-width: 440px;
      box-shadow: 0 2px 12px rgba(0,0,0,0.08);
    }

    .logo {
      font-size: 32px;
      margin-bottom: 8px;
    }

    h1 {
      font-size: 22px;
      color: #111;
      margin-bottom: 4px;
    }

    .subtitle {
      font-size: 14px;
      color: #999;
      margin-bottom: 32px;
    }

    .divider {
      border: none;
      border-top: 1px solid #eee;
      margin: 24px 0;
      position: relative;
    }

    .divider-label {
      position: absolute;
      top: -10px;
      left: 50%;
      transform: translateX(-50%);
      background: white;
      padding: 0 10px;
      font-size: 12px;
      color: #bbb;
    }

    .btn {
      width: 100%;
      padding: 12px;
      border-radius: 8px;
      font-size: 15px;
      font-weight: 500;
      cursor: pointer;
      border: none;
      transition: background 0.2s;
    }

    .btn-primary {
      background: #6c63ff;
      color: white;
    }

    .btn-primary:hover { background: #574fd6; }

    .btn-secondary {
      background: #f0f0f0;
      color: #333;
      margin-top: 10px;
    }

    .btn-secondary:hover { background: #e5e5e5; }

    .input {
      width: 100%;
      padding: 11px 14px;
      border: 1px solid #ddd;
      border-radius: 8px;
      font-size: 14px;
      outline: none;
      margin-bottom: 10px;
      transition: border-color 0.2s;
    }

    .input:focus { border-color: #6c63ff; }

    .error {
      font-size: 13px;
      color: #ef4444;
      margin-top: -4px;
      margin-bottom: 8px;
      display: none;
    }

    .section-label {
      font-size: 13px;
      font-weight: 500;
      color: #555;
      margin-bottom: 10px;
    }
  </style>
</head>
<body>

  <div class="card">
    <div class="logo">⚡</div>
    <h1>P2P File Share</h1>
    <p class="subtitle">Send files directly to another browser — no upload, no cloud.</p>

    <div class="section-label">Create a new room</div>
    <button class="btn btn-primary" id="btn-create">Create room</button>

    <div class="divider"><span class="divider-label">or</span></div>

    <div class="section-label">Join an existing room</div>
    <input class="input" id="input-room" type="text" placeholder="Enter room ID" />
    <p class="error" id="error-msg">Please enter a room ID</p>
    <button class="btn btn-secondary" id="btn-join">Join room</button>
  </div>

  <script>
  document.getElementById('btn-create').onclick = () => {
    window.location.href = '/create-room';
  };

  document.getElementById('btn-join').onclick = () => {
    const roomId = document.getElementById('input-room').value.trim();
    if (roomId) {
      window.location.href = '/room/' + roomId;
    } else {
      document.getElementById('error-msg').style.display = 'block';
    }
  };

  document.getElementById('input-room').onkeydown = (e) => {
    if (e.key === 'Enter') document.getElementById('btn-join').click();
  };

  document.getElementById('input-room').oninput = () => {
    document.getElementById('error-msg').style.display = 'none';
  };
  </script>

</body>
</html>